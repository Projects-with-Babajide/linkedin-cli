  },
  "keywords": [
    "cli",
    "professional-network",
    "claude-code",
    "productivity"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "keytar": "^7.9.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
