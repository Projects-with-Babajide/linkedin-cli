{
  "name": "link-pulse",
  "version": "0.2.1",
  "description": "Personal CLI for managing your professional network from the terminal",
  "author": "Babajide Okusanya",
  "license": "ISC",
  "type": "commonjs",
  "bin": {
    "link-pulse": "dist/bin/linkedin.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node bin/linkedin.ts",
    "start": "node dist/bin/linkedin.js",
    "prepublishOnly": "tsc",
